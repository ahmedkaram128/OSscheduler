<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<BorderPane prefHeight="900.0" prefWidth="1450.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="GUI.DashboardController">

    <top>
        <VBox spacing="10.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>

            <Label text="Operating System Simulator Dashboard"
                   style="-fx-font-size: 22px; -fx-font-weight: bold;" />

            <HBox spacing="12.0" alignment="CENTER_LEFT">
                <Label text="Algorithm:"/>
                <Label fx:id="algorithm" prefWidth="150.0"/>

                <Label text="Quantum:"/>
                <Label fx:id="quantum" prefWidth="80.0" />

                <Label text="Clock Cycle:"/>
                <Label fx:id="clockCycleLabel" text="0" style="-fx-font-weight: bold;"/>

                <Label text="Current Time Slice:"/>
                <Label fx:id="timeSliceLabel" text="0" style="-fx-font-weight: bold;"/>

                <Separator orientation="VERTICAL"/>

                <Button fx:id="stepButton" text="Next Step" onAction="#runStep"/>
				<Button fx:id="runAllButton" text="Run All" onAction="#runAll"/>
				<Button fx:id="pauseButton" text="Pause" onAction="#pauseResume"/>
				<Button fx:id="resetButton" text="Reset" onAction="#resetSimulation"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.22,0.72">
            <items>

                <VBox spacing="12.0" prefWidth="300.0">
                    <padding>
                        <Insets top="12" right="12" bottom="12" left="12"/>
                    </padding>

                    <Label text="Queues"
                           style="-fx-font-size: 18px; -fx-font-weight: bold;" />

                    <VBox spacing="6.0">
					    <Label text="Ready Queue"/>
					    <HBox spacing="8.0">
					        <ListView fx:id="readyQueueListView" prefHeight="160.0" HBox.hgrow="ALWAYS"/>
					        <VBox alignment="TOP_CENTER" prefHeight="160.0">
					            <Label text="Top" />
					            <Region VBox.vgrow="ALWAYS"/>
					            <Label text="Bottom" />
					        </VBox>
					    </HBox>
					</VBox>
					
					<VBox spacing="6.0">
					    <Label text="Blocked Queue"/>
					    <HBox spacing="8.0">
					        <ListView fx:id="blockedQueueListView" prefHeight="140.0" HBox.hgrow="ALWAYS"/>
					        <VBox alignment="TOP_CENTER" prefHeight="140.0">
					            <Label text="Top" />
					            <Region VBox.vgrow="ALWAYS"/>
					            <Label text="Bottom" />
					        </VBox>
					    </HBox>
					</VBox>

                    <VBox spacing="6.0">
                        <Label text="Finished Processes"/>
                        <ListView fx:id="finishedProcessesListView" prefHeight="120.0"/>
                    </VBox>

                    <VBox spacing="8.0">
                        <Label text="Activity Monitor"
                               style="-fx-font-size: 16px; -fx-font-weight: bold;" />
                        <ListView fx:id="eventListView" prefHeight="180.0"/>
                    </VBox>
                </VBox>

                <VBox spacing="12.0">
                    <padding>
                        <Insets top="12" right="12" bottom="12" left="12"/>
                    </padding>

                    <Label text="Execution Monitor"
                           style="-fx-font-size: 18px; -fx-font-weight: bold;" />

                    <GridPane hgap="12.0" vgap="10.0">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="25"/>
                            <ColumnConstraints percentWidth="25"/>
                            <ColumnConstraints percentWidth="25"/>
                            <ColumnConstraints percentWidth="25"/>
                        </columnConstraints>

                        <Label text="Running Process:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <Label fx:id="runningProcessLabel" text="None"
                               style="-fx-font-weight: bold;"
                               GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                        <Label text="Current Instruction:" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                        <Label fx:id="currentInstructionLabel" text="---"
                               style="-fx-font-weight: bold;"
                               GridPane.columnIndex="3" GridPane.rowIndex="0"/>

                        <Label text="Process State:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <Label fx:id="processStateLabel" text="---"
                               style="-fx-font-weight: bold;"
                               GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                        <Label text="Program Counter:" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                        <Label fx:id="pcLabel" text="0"
                               style="-fx-font-weight: bold;"
                               GridPane.columnIndex="3" GridPane.rowIndex="1"/>

                    </GridPane>

                    <TabPane VBox.vgrow="ALWAYS">
                        <tabs>

                            <Tab text="Memory">
                                <BorderPane>
                                    <top>
                                        <HBox spacing="10.0" alignment="CENTER_LEFT">
                                            <padding>
                                                <Insets top="10" right="10" bottom="10" left="10"/>
                                            </padding>
                                            <Label text="Main Memory (40 words)"
                                                   style="-fx-font-size: 15px; -fx-font-weight: bold;" />

                                        </HBox>
                                    </top>

                                    <center>
                                        <ScrollPane fitToWidth="true" fitToHeight="true">
                                            <content>
                                                <GridPane fx:id="memoryGrid"
                                                          hgap="8.0" vgap="8.0"
                                                          style="-fx-background-color: white;">
                                                    <padding>
                                                        <Insets top="10" right="10" bottom="10" left="10"/>
                                                    </padding>
                                                    <columnConstraints>
                                                        <ColumnConstraints percentWidth="20"/>
                                                        <ColumnConstraints percentWidth="20"/>
                                                        <ColumnConstraints percentWidth="20"/>
                                                        <ColumnConstraints percentWidth="20"/>
                                                        <ColumnConstraints percentWidth="20"/>
                                                    </columnConstraints>
                                                    <rowConstraints>
                                                        <RowConstraints prefHeight="75"/>
                                                        <RowConstraints prefHeight="75"/>
                                                        <RowConstraints prefHeight="75"/>
                                                        <RowConstraints prefHeight="75"/>
                                                        <RowConstraints prefHeight="75"/>
                                                        <RowConstraints prefHeight="75"/>
                                                        <RowConstraints prefHeight="75"/>
                                                        <RowConstraints prefHeight="75"/>
                                                    </rowConstraints>
                                                </GridPane>
                                            </content>
                                        </ScrollPane>
                                    </center>
                                </BorderPane>
                            </Tab>

                            <Tab text="Disk">
                                <BorderPane>
                                    <top>
                                        <HBox spacing="10.0" alignment="CENTER_LEFT">
                                            <padding>
                                                <Insets top="10" right="10" bottom="10" left="10"/>
                                            </padding>
                                            <Label text="Disk / Swapped Processes"
                                                   style="-fx-font-size: 15px; -fx-font-weight: bold;" />
                                        </HBox>
                                    </top>
                                    <center>
                                        <TextArea fx:id="diskTextArea" editable="false" wrapText="true"/>
                                    </center>
                                </BorderPane>
                            </Tab>
							
								<Tab fx:id="mlfqTab" text="MLFQ Queues">						    <BorderPane>
						
						        <top>
						            <HBox spacing="10.0" alignment="CENTER_LEFT">
						                <padding>
						                    <Insets top="10" right="10" bottom="10" left="10"/>
						                </padding>
						                <Label text="Multi-Level Feedback Queues"
						                       style="-fx-font-size: 15px; -fx-font-weight: bold;" />
						            </HBox>
						        </top>
						
						        <center>
						            <GridPane hgap="15" vgap="10">
						                <padding>
						                    <Insets top="10" right="10" bottom="10" left="10"/>
						                </padding>
						
						                <VBox spacing="5">
						                    <Label text="Q0 (q=1)" style="-fx-font-weight: bold;"/>
						                    <ListView fx:id="q0ListView"/>
						                </VBox>
						
						                <VBox spacing="5" GridPane.columnIndex="1">
						                    <Label text="Q1 (q=2)" style="-fx-font-weight: bold;"/>
						                    <ListView fx:id="q1ListView"/>
						                </VBox>
						
						                <VBox spacing="5" GridPane.columnIndex="2">
						                    <Label text="Q2 (q=4)" style="-fx-font-weight: bold;"/>
						                    <ListView fx:id="q2ListView"/>
						                </VBox>
						
						                <VBox spacing="5" GridPane.columnIndex="3">
						                    <Label text="Q3 (q=8)" style="-fx-font-weight: bold;"/>
						                    <ListView fx:id="q3ListView"/>
						                </VBox>
						
						            </GridPane>
						        </center>
						
						    </BorderPane>
						</Tab>
					
                        </tabs>
                    </TabPane>
                </VBox>

                <VBox spacing="12.0" prefWidth="330.0">
                    <padding>
                        <Insets top="12" right="12" bottom="12" left="12"/>
                    </padding>

                    <Label text="System Status"
                           style="-fx-font-size: 18px; -fx-font-weight: bold;" />

                    <VBox spacing="8.0" style="-fx-border-color: #cccccc; -fx-padding: 10;">
                        <Label text="Current Running Process Details"
                               style="-fx-font-size: 15px; -fx-font-weight: bold;" />
                        <Label fx:id="runningPidLabel" text="PID: ---"/>
                        <Label fx:id="runningStateLabel" text="State: ---"/>
                        <Label fx:id="runningStartLabel" text="Memory Start: ---"/>
                        <Label fx:id="runningEndLabel" text="Memory End: ---"/>
                        <Label fx:id="runningArrivalLabel" text="Arrival Time: ---"/>
                    </VBox>

                    <VBox spacing="8.0" style="-fx-border-color: #cccccc; -fx-padding: 10;">
                        <Label text="Mutex / Resources"
                               style="-fx-font-size: 15px; -fx-font-weight: bold;" />
                        <Label fx:id="userInputMutexLabel" text="userInput: Free"/>
                        <Label fx:id="userOutputMutexLabel" text="userOutput: Free"/>
                        <Label fx:id="fileMutexLabel" text="file: Free"/>
                    </VBox>

                    <VBox spacing="8.0" style="-fx-border-color: #cccccc; -fx-padding: 10;">
                        <Label text="Arrivals Configuration"
                               style="-fx-font-size: 15px; -fx-font-weight: bold;" />
                        <Label fx:id="p1ArrivalLabel" text="P1 Arrival: 0"/>
                        <Label fx:id="p2ArrivalLabel" text="P2 Arrival: 1"/>
                        <Label fx:id="p3ArrivalLabel" text="P3 Arrival: 4"/>
                    </VBox>

                    <VBox spacing="8.0" VBox.vgrow="ALWAYS" style="-fx-border-color: #cccccc; -fx-padding: 10;">
                        <Label text="General Console Output"
                               style="-fx-font-size: 15px; -fx-font-weight: bold;" />
                        <TextArea fx:id="consoleOutputTextArea" editable="false" wrapText="true" VBox.vgrow="ALWAYS"/>
                        <TextField fx:id = "userInput" />
                        <Button fx:id="submitUserInput" text="Enter" onAction="#submitInput"/>
                        
                    </VBox>
                </VBox>

            </items>
        </SplitPane>
    </center>

    <bottom>
        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <padding>
                <Insets top="10" right="12" bottom="10" left="12"/>
            </padding>

        </HBox>
    </bottom>

</BorderPane>