<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="750.0" prefWidth="1100.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="GUI.WelcomeController">

    <top>
        <VBox spacing="10">
            <padding>
                <Insets bottom="10" left="20" right="20" top="20" />
            </padding>

            <Label style="-fx-font-size: 26px; -fx-font-weight: bold;" text="Operating System Simulator" />

            <Label style="-fx-font-size: 14px;" text="Configure processes, arrival times, and scheduling before starting." />
        </VBox>
    </top>

    <center>
        <HBox spacing="20">
            <padding>
                <Insets bottom="20" left="20" right="20" top="10" />
            </padding>

            <VBox prefWidth="350" spacing="15" style="-fx-background-color: white; -fx-border-color: #cccccc; -fx-padding: 20;">

                <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="General Settings" />

                <GridPane hgap="10" vgap="12">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="40" />
                        <ColumnConstraints percentWidth="60" />
                    </columnConstraints>

                    <Label text="Algorithm:" GridPane.rowIndex="0" />
                    <ComboBox fx:id="algorithmComboBox" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                    <Label text="Quantum:" GridPane.rowIndex="1" />
                    <TextField fx:id="quantumField" promptText="RR only" GridPane.columnIndex="1" GridPane.rowIndex="1" />
               <rowConstraints>
                  <RowConstraints />
                  <RowConstraints />
               </rowConstraints>
                </GridPane>

                <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Instructions" />

                <TextArea editable="false" prefHeight="200" text="1) Enter arrival time for each process. 2) Choose execution order. 3) Select scheduling algorithm. 4) Click Launch Simulation." wrapText="true" />
            </VBox>

            <VBox prefWidth="650" spacing="15" style="-fx-background-color: white; -fx-border-color: #cccccc; -fx-padding: 20;">

                <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Process Configuration" />

                <GridPane hgap="10" vgap="12">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="20" />
                        <ColumnConstraints percentWidth="30" />
                        <ColumnConstraints percentWidth="20" />
                        <ColumnConstraints percentWidth="30" />
                    </columnConstraints>

                    <Label style="-fx-font-weight: bold;" text="Process" GridPane.rowIndex="0" />
                    <Label style="-fx-font-weight: bold;" text="Program File" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                    <Label style="-fx-font-weight: bold;" text="Arrival Time" GridPane.columnIndex="2" GridPane.rowIndex="0" />

                    <Label text="P1" GridPane.rowIndex="1" />
                    <TextField fx:id="p1File" text="Program 1.txt" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                    <TextField fx:id="p1Arrival" promptText="e.g. 0" GridPane.columnIndex="2" GridPane.rowIndex="1" />

                    <Label text="P2" GridPane.rowIndex="2" />
                    <TextField fx:id="p2File" text="Program_2.txt" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                    <TextField fx:id="p2Arrival" promptText="e.g. 1" GridPane.columnIndex="2" GridPane.rowIndex="2" />

                    <Label text="P3" GridPane.rowIndex="3" />
                    <TextField fx:id="p3File" text="Program_3.txt" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                    <TextField fx:id="p3Arrival" promptText="e.g. 4" GridPane.columnIndex="2" GridPane.rowIndex="3" />
               <rowConstraints>
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
               </rowConstraints>
                </GridPane>

                <HBox spacing="10">
                    <Button fx:id="startButton" style="-fx-font-weight: bold;" text="Launch Simulation" onAction="#startSimulation" />
                    <Label fx:id="errorState" text="" style="-fx-text-fill: red; -fx-font-weight: bold;" />
                </HBox>
            </VBox>
        </HBox>
    </center>

</BorderPane>
